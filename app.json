{
  "expo": {
    "name": "West Coast Picker",
    "slug": "bidwave",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "co.za.bidwave.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D1B2A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "co.za.bidwave.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single",
      "name": "West Coast Picker",
      "shortName": "WC Pickers",
      "description": "South Africa's live & timed auction marketplace. Bid on vehicles, livestock, property, electronics and more.",
      "themeColor": "#0D1B2A",
      "backgroundColor": "#0D1B2A",
      "display": "standalone",
      "orientation": "any",
      "scope": "/",
      "startUrl": "/",
      "lang": "en-ZA",
      "dir": "ltr",
      "preferRelatedApplications": false
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      [
        "expo-image-picker",
        {
          "photosPermission": "BidWave needs photo access to upload lot images."
        }
      ]
    ],
    "scheme": "bidwave"
  }
}
